# Local .terraform / .tofu directories
**/.terraform/*
**/.tofu/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files that may contain secrets
*.tfvars
*.tfvars.json
!example.tfvars
!example.tfvars.json

# Plan output
*.tfplan
*.tfplan.*

# Override files — typically used for local dev
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
